									"    pm.expect(jsonData).to.have.property('nomeCriptografado');",
									"    pm.expect(jsonData).to.have.property('emailCriptografado');",
									"    pm.expect(jsonData).to.have.property('chavePublica');",
									"});",
									"",
									"pm.test(\"Encrypted fields are not empty\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.nomeCriptografado).to.not.be.empty;",
									"    pm.expect(jsonData.emailCriptografado).to.not.be.empty;",
