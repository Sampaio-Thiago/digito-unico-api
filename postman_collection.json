				{
					"name": "Calcular Dígito Único - Caso Simples",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has calculation result\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('resultado');",
									"    pm.expect(jsonData).to.have.property('n');",
									"    pm.expect(jsonData).to.have.property('k');",
									"    pm.expect(jsonData).to.have.property('usuarioId');",
									"});",
									"",
									"pm.test(\"Calculation result is correct\", function () {",
									"    var jsonData = pm.response.json();",
									"    // Para n=9875, k=4 o resultado esperado é 8",
									"    pm.expect(jsonData.resultado).to.be.a('number');",
									"    pm.expect(jsonData.resultado).to.be.at.least(1);",
									"    pm.expect(jsonData.resultado).to.be.at.most(9);",
									"});",
									"",
									"pm.test(\"Input values are preserved\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.n).to.eql('9875');",
									"    pm.expect(jsonData.k).to.eql(4);",
									"});"
								],
								"type": "text/javascript"
							}
						}
