				{
					"name": "Calcular Dígito Único - Caso Complexo",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"digitoUnico is a single digit (1-9)\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.digitoUnico).to.be.a('number');",
									"    pm.expect(jsonData.digitoUnico).to.be.at.least(1);",
									"    pm.expect(jsonData.digitoUnico).to.be.at.most(9);",
									"});"
								],
								"type": "text/javascript"
