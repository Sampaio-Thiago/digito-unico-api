								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"n\": \"123456789\",\n  \"k\": 10,\n  \"usuarioId\": {{usuarioId}}\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/calculos/digito-unico",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"calculos",
								"digito-unico"
							]
