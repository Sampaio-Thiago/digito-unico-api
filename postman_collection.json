		{
			"name": "Cálculos",
			"item": [
				{
					"name": "Calcular Dígito Único - Caso Simples (n=9875, k=4 → 8)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Response has correct fields\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('digitoUnico');",
									"    pm.expect(jsonData).to.have.property('n');",
									"    pm.expect(jsonData).to.have.property('k');",
									"    pm.expect(jsonData).to.have.property('fromCache');",
									"});",
									"",
									"pm.test(\"Calculation result is correct (9875 * 4 = 8)\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.digitoUnico).to.eql(8);",
									"});",
									"",
									"pm.test(\"Input values are preserved\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.n).to.eql('9875');",
									"    pm.expect(jsonData.k).to.eql(4);",
									"});",
									"",
									"pm.test(\"First call is not from cache\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.fromCache).to.eql(false);",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
					"request": {
						"method": "POST",
						"header": [
							{
								"key": "Content-Type",
								"value": "application/json"
							}
						],
						"body": {
							"mode": "raw",
							"raw": "{\n  \"n\": \"9875\",\n  \"k\": 4,\n  \"usuarioId\": {{usuarioId}}\n}"
						},
						"url": {
							"raw": "{{baseUrl}}/api/calculos/digito-unico",
							"host": [
								"{{baseUrl}}"
							],
							"path": [
								"api",
								"calculos",
								"digito-unico"
							]
						}
					}
				},
				{
					"name": "Calcular Dígito Único - Cache (mesma entrada → fromCache true)",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 200\", function () {",
									"    pm.response.to.have.status(200);",
									"});",
									"",
									"pm.test(\"Second call comes from cache\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.fromCache).to.eql(true);",
									"});",
									"",
									"pm.test(\"Result is still correct\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.digitoUnico).to.eql(8);",
									"});"
								],
								"type": "text/javascript"
							}
						}
