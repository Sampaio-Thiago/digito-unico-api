				{
					"name": "Criar Usuário",
					"event": [
						{
							"listen": "test",
							"script": {
								"exec": [
									"pm.test(\"Status code is 201\", function () {",
									"    pm.response.to.have.status(201);",
									"});",
									"",
									"pm.test(\"Response has user data\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData).to.have.property('id');",
									"    pm.expect(jsonData).to.have.property('nome');",
									"    pm.expect(jsonData).to.have.property('email');",
									"    ",
									"    // Salvar ID do usuário para próximos testes",
									"    pm.collectionVariables.set('usuarioId', jsonData.id);",
									"});",
									"",
									"pm.test(\"User name is correct\", function () {",
									"    var jsonData = pm.response.json();",
									"    pm.expect(jsonData.nome).to.eql('João Silva');",
									"});"
								],
								"type": "text/javascript"
							}
						}
					],
